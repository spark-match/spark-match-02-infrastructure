# =============================================================================
# Spark Match Infrastructure (02-infrastructure) - .gitignore
# =============================================================================
# Stack: Terraform (VPC, Aurora, EventBridge, S3, IAM, Secrets)
# Helper scripts: Python (boto3) + Bash
# =============================================================================

# -----------------------------------------------------------------------------
# Terraform local cache and state
# -----------------------------------------------------------------------------
.terraform/
.terraform.lock.hcl
.terraform.d/
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log

# -----------------------------------------------------------------------------
# Plan files (locales)
# -----------------------------------------------------------------------------
tfplan
tfplan.json
*.tfplan
*.tfplan.json

# -----------------------------------------------------------------------------
# tfvars con secretos (solo se commitea el .example)
# -----------------------------------------------------------------------------
*.tfvars
!*.tfvars.example
!example.tfvars

# -----------------------------------------------------------------------------
# Terragrunt cache (si se usa en el futuro)
# -----------------------------------------------------------------------------
.terragrunt-cache/

# -----------------------------------------------------------------------------
# Pre-commit cache
# -----------------------------------------------------------------------------
.cache/

# -----------------------------------------------------------------------------
# Python (helper scripts con boto3)
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.python-version
.uv/
uv.lock
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
*.egg-info/

# -----------------------------------------------------------------------------
# AWS credentials y configs locales
# -----------------------------------------------------------------------------
.aws/
credentials
config.local
*.pem
*.key
*.crt

# -----------------------------------------------------------------------------
# Node.js (actionlint via npx en CI)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*

# -----------------------------------------------------------------------------
# Editor / OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
