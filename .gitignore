# Terraform local cache and state
.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log

# Lock file: SI se commitea (reproducibilidad de versiones de providers).
# Solo gitignore si existe override local. La convencion es commitearlo.
!.terraform.lock.hcl

# Plan files (locales)
tfplan
tfplan.json

# Tfvars con secretos (NO se commitea terraform.tfvars.local ni *.secret.tfvars).
# Pero SI se commitean los tfvars "base" de cada env (sin secretos), porque
# contienen la config de la infra (CIDR, NAT, endpoints, etc.) que todos los devs
# necesitan sincronizada.
*.tfvars
!*.tfvars.example
!terraform.tfvars

# Plugin cache
.terraform.d/

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Pre-commit cache
.cache/

# Terragrunt cache (si se usa en el futuro)
.terragrunt-cache/
